{
  "name": "experimentation-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "dev:dashboard": "pnpm --filter dashboard dev",
    "build:dashboard": "pnpm --filter dashboard build",
    "test": "pnpm --filter api test && pnpm --filter dashboard test",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "test:integration": "playwright test --config playwright.integration.config.ts",
    "test:demo": "playwright test --config playwright.demo.config.ts",
    "test:demo:report": "playwright show-report playwright-report/demo",
    "start": "bash scripts/start.sh all",
    "stop": "bash scripts/stop.sh all",
    "restart": "bash scripts/restart.sh all",
    "start:web": "bash scripts/start.sh web",
    "stop:web": "bash scripts/stop.sh web",
    "restart:web": "bash scripts/restart.sh web",
    "start:dashboard": "bash scripts/start.sh dashboard",
    "stop:dashboard": "bash scripts/stop.sh dashboard",
    "restart:dashboard": "bash scripts/restart.sh dashboard",
    "start:api": "bash scripts/start.sh api",
    "stop:api": "bash scripts/stop.sh api",
    "restart:api": "bash scripts/restart.sh api",
    "start:docker": "bash scripts/start.sh docker",
    "stop:docker": "bash scripts/stop.sh docker",
    "demo:reset": "bash scripts/demo-reset.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "playwright": "^1.58.2",
    "vitest": "^4.0.18"
  }
}
