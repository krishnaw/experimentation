# Experimentation Platform — Environment Variables
# Copy this file to apps/web/.env.local and fill in your actual values.
# -----------------------------------------------------------------------

# === GrowthBook ===
# Get these after running `docker compose up -d` and creating your account at http://localhost:3000

# GrowthBook API URL (don't change unless you modified docker-compose.yml)
GROWTHBOOK_API_URL=http://localhost:3100

# GrowthBook UI URL (don't change unless you modified docker-compose.yml)
GROWTHBOOK_APP_URL=http://localhost:3000

# Secret API key — create at Settings > API Keys (starts with "secret_")
# Used by the chat agent to manage experiments and features
GROWTHBOOK_SECRET_API_KEY=secret_your_key_here

# === SDK Keys (client-side + server-side feature flags) ===

# GrowthBook SDK host for client-side feature flags
NEXT_PUBLIC_GROWTHBOOK_API_HOST=http://localhost:3100

# SDK Client key — create at SDK Connections > New Connection (starts with "sdk-")
# Used by the React SDK to load feature flag values
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=sdk-your_client_key_here

# Same SDK Client key for server-side API route (product sort order)
GROWTHBOOK_CLIENT_KEY=sdk-your_client_key_here

# === LLM Providers (at least one required for the chat agent) ===
# The chat tries providers in this order: Cerebras > Mistral > Groq > Anthropic
# You only need ONE key, but you can set multiple for fallback.

# Cerebras — fastest, free tier — get key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Mistral — free tier — get key at https://console.mistral.ai
MISTRAL_API_KEY=

# Groq — fast, free tier — get key at https://console.groq.com
GROQ_API_KEY=

# Anthropic — most reliable, paid — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=
