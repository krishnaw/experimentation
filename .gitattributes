# Normalize all text files to LF in the repo.
# On Windows, git will still check out CRLF if core.autocrlf=true,
# but the stored bytes in the repo are always LF — no cross-OS diff noise.
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webm binary
*.mp4  binary
*.pdf  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.eot  binary
*.zip  binary
